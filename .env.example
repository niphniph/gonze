# Cloudflare Credentials (for local Wrangler dev & deployment scripting)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_PROJECT_NAME=productivity-tracker
CLOUDFLARE_D1_DATABASE_ID=your_cloudflare_d1_database_id_here

# Application configuration (configure in local dev wrangler.json or Cloudflare Dashboard)
JWT_SECRET=your_jwt_secret_token_here
EMAIL_PROVIDER_API_KEY=your_resend_api_key_here
APP_URL=http://localhost:5173
